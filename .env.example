# ─── Frontend Environment Variables ───────────────────────────────────────────

# API URL (leave empty for development - Vite proxy handles it)
# Set to full URL for production builds (e.g., https://api.wayzo.net/api)
VITE_API_URL=

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
